# ══════════════════════════════════════════════════════════
#  AdGuard .env.example — 값 채운 후 .env로 저장
# ══════════════════════════════════════════════════════════

# ── Azure OpenAI ──────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<리소스명>.openai.azure.com/
AZURE_OPENAI_API_KEY=<YOUR_KEY_HERE>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_REGION=eastus
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_API_VERSION=2023-05-15

# 기존 백엔드 네이밍 (파이프라인 호환용)
AOAI_KEY=<AZURE_OPENAI_API_KEY와 동일>
AOAI_ENDPOINT=<AZURE_OPENAI_ENDPOINT와 동일>
AOAI_DEPLOYMENT=gpt-4o
AOAI_DEPLOYMENT_MINI=gpt-4o

# ── Azure AI Search ───────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<리소스명>.search.windows.net
AZURE_SEARCH_API_KEY=<YOUR_KEY_HERE>
AZURE_SEARCH_INDEX_NAME=adguard-main

# 기존 백엔드 네이밍 (파이프라인 호환용)
SEARCH_ENDPOINT=<AZURE_SEARCH_ENDPOINT와 동일>
SEARCH_KEY=<AZURE_SEARCH_API_KEY와 동일>
SEARCH_INDEX_NAME=adguard-main

# ── Azure Storage (Blob + Table) ──────────────────────────
BLOB_CONN_STR=DefaultEndpointsProtocol=https;AccountName=<계정명>;AccountKey=<키>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONNECTION_STRING=<BLOB_CONN_STR와 동일>

# ── Azure Document Intelligence (OCR) ────────────────────
DOCINTEL_ENDPOINT=https://<리소스명>.cognitiveservices.azure.com/
DOCINTEL_KEY=<YOUR_KEY_HERE>
AZURE_DOCINTEL_ENDPOINT=<DOCINTEL_ENDPOINT와 동일>
AZURE_DOCINTEL_KEY=<DOCINTEL_KEY와 동일>
